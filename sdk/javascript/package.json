{
  "name": "@fide-work/id",
  "version": "0.0.0-alpha.14",
  "description": "Fide ID SDK (v0)",
  "license": "Apache-2.0",
  "author": "Fide Holdings, Inc. (https://github.com/fide)",
  "repository": {
    "type": "git",
    "url": "https://github.com/fide/id.git"
  },
  "homepage": "https://fide.work/docs/id",
  "keywords": [
    "fide",
    "fide-id",
    "did",
    "identity",
    "id"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "pnpm run build && node scripts/test-runner.mjs",
    "test:verbose": "pnpm run build && node scripts/test-runner.mjs --verbose",
    "generate:docs": "node ../../scripts/generate-docs/sdk-reference.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fide-work/vocabulary": "alpha"
  }
}
